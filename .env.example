# --- Database ---
# SQLite file path (Docker: point at a mounted volume, e.g. file:/data/airvpn.db)
DATABASE_URL="file:./dev.db"

# --- App ---
# Canonical origin of the deployed app. Used for links in emails,
# WebAuthn rpID/expectedOrigin and CSRF origin checks.
APP_ORIGIN='http://localhost:3001'

# --- Secrets ---
# Generate each with: openssl rand -base64 32
# WARNING: losing ENCRYPTION_MASTER_KEY makes all stored AirVPN keys / TOTP
# secrets unrecoverable. Keep a copy in a password manager.
ENCRYPTION_MASTER_KEY=''
PENDING_AUTH_SECRET=''

# --- SMTP (email verification / password reset) ---
# NOTE: escape any $ in values as \$ (Next.js expands $VAR in .env files).
SMTP_HOST=''
SMTP_PORT='465'
SMTP_SECURE='true'
SMTP_USER=''
SMTP_PASSWORD=''
SMTP_FROM='Air-Dash <no-reply@example.com>'
